# ─────────────────────────────────────────────────────────────────────────────
# regime_trader — environment template
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca ────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Paper trading endpoint (safe default — change to live URL when ready)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# WebSocket stream endpoint
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2
# portfolio_sync.py endpoint overrides (optional — defaults shown)
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_URL=https://api.alpaca.markets

# Trading mode: paper | live
ENV=paper

# Paper-trading flag read by broker/alpaca_client.py (true = safe default)
ALPACA_PAPER=true

# ── Email Alerts (SMTP / Gmail app password) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx     # Gmail app password (not your login password)
ALERT_RECIPIENT=your_email@gmail.com

# ── SMS Alerts (Twilio) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx

# ── Webhook Alerts (Slack / Discord / custom) ─────────────────────────────────
WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Market Intelligence — Enhanced Sources ────────────────────────────────────
# QuiverQuant API key for congressional trading data (market_intel/market_intel_data.py)
# Free tier available at: https://www.quiverquant.com
# Without this key, the scraper fallback (Capitol Trades) is used automatically.
QUIVER_API_KEY=

# Fintel.io API key for short-interest / short-squeeze scores
# Paid plans at: https://fintel.io/plans
# Without this key, Fintel scores default to 0.50 (neutral).
FINTEL_API_KEY=

# Finnhub API key — news sentiment + analyst recommendations (free tier: 60 req/min)
# Get a free key at: https://finnhub.io/dashboard
# Enables fetch_finnhub_news_sentiment() and fetch_finnhub_recommendation_score()
FINNHUB_API_KEY=

# Financial Modeling Prep API key — insider trading + institutional ownership
# Plans at: https://site.financialmodelingprep.com/developer/docs/dashboard
# Enables fetch_fmp_insider_score() and fetch_fmp_institutional_score() in market_intel_macro.py
FMP_API_KEY=

# Alpha Vantage API key for news sentiment (intelligence/sources.py — AlphaVantageNewsFetcher)
# Free tier: 25 calls/day, no credit card required.
# Get a free key at: https://www.alphavantage.co/support/#api-key
# Without this key, Alpha Vantage news scores default to 0.50 (neutral).
ALPHA_VANTAGE_API_KEY=

# ── Optional: override log level at runtime ───────────────────────────────────
# LOG_LEVEL=DEBUG
