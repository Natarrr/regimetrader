[run]
# Alpha-Critical: measure only the core scoring / signal engine
source =
    backend/market_intel
    src/scoring

omit =
    # Live scaffolding — hard to unit-test, not trading logic
    monitoring/*
    # Data ingestion / offline tools
    backend/data/*
    scripts/backtest_signals.py
    scripts/mock_webhook_server.py
    scripts/check_imports.py
    scripts/check_secrets.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    ^\s*\.\.\.$
