# Insider Alpha thresholds
_OPEN_MARKET_TYPES = {"P-PURCHASE", "PURCHASE", "OPEN MARKET PURCHASE"}
_INSIDER_ROLE_BOOST = {"CEO", "CFO", "DIRECTOR", "CHIEF EXECUTIVE", "CHIEF FINANCIAL OFFICER"}
_INSIDER_MIN_AMOUNT_FORCE = 50_000.0          # $50k triggers force multiplier
_INSIDER_OPEN_MARKET_MIN = 30                 # days
_INSIDER_CONVICTION_FLOOR = 0.85              # Open Market CEO/CFO/Director buy

# Institutional Whales thresholds
_MAJOR_FUNDS = {"BLACKROCK", "VANGUARD", "RENAISSANCE", "STATE STREET", "FIDELITY", "JP MORGAN"}
_INST_MAJOR_INCREASE_THRESHOLD = 0.05         # 5% position increase
_INST_WHALE_BOOST = 0.40                       # institutional dominates weight

# Social & News Sentiment thresholds
_SENTIMENT_ZSPIKE_THRESHOLD = 2.0             # 2x normal volume
_SENTIMENT_CORRELATION_BOOST = 0.40           # weight when news+social correlated

# Signal Override thresholds
_CONVERGENCE_ALPHA_THRESHOLD = 0.90           # both ins & sent > 0.90
_CONVERGENCE_ALPHA_MIN = 0.95                 # Global Score minimum

_NEUTRAL = 0.50

# ── Signal thresholds ─────────────────────────────────────────────────────────

_LONG_THRESHOLD:    float = 0.58
_SHORT_THRESHOLD:   float = 0.42
_MIN_TARGET_WEIGHT: float = 0.02
_MAX_TARGET_WEIGHT: float = 0.20
_TOP_N: int = 5

