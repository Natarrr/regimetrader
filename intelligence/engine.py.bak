# ══════════════════════════════════════════════════════════════════════════════
# Cache helpers  (tuple-aware: stores (score, metadata) pairs)
# ══════════════════════════════════════════════════════════════════════════════

def _cache_get_pillar(key: str) -> Optional[Tuple[float, Dict]]:
    """Return cached (score, metadata) or None on miss / legacy float hit."""
    if _USE_DISK and _disk is not None:
        val = _disk.get(key)
        if val is None:
            return None
        if isinstance(val, tuple) and len(val) == 2:
            return val
        return float(val), {}   # legacy single-float entry
    entry = _mem.get(key)
    if entry and time.monotonic() < entry["exp"]:
        val = entry["val"]
        if isinstance(val, tuple):
            return val
        return float(val), {}
    return None


def _cache_set_pillar(key: str, score: float, meta: Dict, ttl: float) -> None:
    if _USE_DISK and _disk is not None:
        _disk.set(key, (score, meta), expire=ttl)
    else:
        _mem[key] = {"val": (score, meta), "exp": time.monotonic() + ttl}


def is_pillar_cached(ticker: str, pillar: str) -> bool:
    """Check if a specific pillar is cached (fresh or stale)."""
    cache_key = f"p3:{pillar}:{ticker.upper()}"
    if _USE_DISK and _disk is not None:
        return _disk.get(cache_key) is not None
    return cache_key in _mem


def get_cached_pillars(ticker: str) -> Dict[str, bool]:
    """Return dict of pillar -> whether cached (any freshness)."""
    pillars = ["sent", "ins", "inst", "news", "macro"]
    return {p: is_pillar_cached(ticker, p) for p in pillars}


# ══════════════════════════════════════════════════════════════════════════════
# Math helpers
# ══════════════════════════════════════════════════════════════════════════════

def _clamp(v: float, lo: float = 0.0, hi: float = 1.0) -> float:
    return round(max(lo, min(hi, v)), 4)


def _geometric_weighted_mean(
    scores: Dict[str, float], weights: Dict[str, float]
) -> float:
    """
    Geometric weighted mean; missing pillars are excluded and remaining
    weights are re-normalised to sum to 1.0.
    """
    active = {k: v for k, v in scores.items() if k in weights}
    if not active:
        return _NEUTRAL
    w_total = sum(weights[k] for k in active)
    if w_total == 0:
        return _NEUTRAL
    log_sum = sum(
        (weights[k] / w_total) * math.log(max(1e-4, min(1.0, s)))
        for k, s in active.items()
    )
    return round(math.exp(log_sum), 4)


def _time_decay(score: float, age_days: float, half_life: float = 21.0) -> float:
    if age_days <= 0.0:
        return score
    lam = math.log(2.0) / max(half_life, 1.0)
    return _clamp(_NEUTRAL + (score - _NEUTRAL) * math.exp(-lam * age_days))


# ══════════════════════════════════════════════════════════════════════════════
# Dynamic weighting
# ══════════════════════════════════════════════════════════════════════════════

def calculate_dynamic_weights(
    pillar_meta: Dict[str, Dict],
    base_weights: Optional[Dict[str, float]] = None,
    scores: Optional[Dict[str, float]] = None,
) -> Tuple[Dict[str, float], float, List[str]]:
    """
    Compute dynamic pillar weights from signal conviction and data availability.

    ENHANCED RULES (per user request):
    ─────────────────────────────────
    1. High Conviction  : CEO/C-suite FMP insider purchase > $1M → ins boosted to 40%
    2. Momentum         : StockTwits volume > 2σ → sent boosted proportionally
    3. Data Availability: pillar with has_data=False → weight redistributed to active ones
    4. Smart Money      : ins + inst both > 0.62 → hard data outweighs soft signals
    5. CONVERGENCE ALPHA: Insider > 0.90 AND Sentiment > 0.90 → Global Score = 0.95 min
    6. Social/News Correlation: both positive → Sentiment weight boosted to 40%

    Parameters
    ----------
    pillar_meta   : {pillar: {has_data, ceo_purchase_amount?, volume_zscore?, ...}}
    base_weights  : starting weights (defaults to _BASE_WEIGHTS: equal 20% each)
    scores        : raw pillar scores {pillar: float} — enables conviction-aware rules

    Returns
    -------
    weights    : {pillar: float} normalised so Σ = 1.0
    confidence : fraction of pillars with real data [0.0 – 1.0]
    triggers   : list of human-readable rule labels that fired
    """
    bw = base_weights if base_weights is not None else _BASE_WEIGHTS
    weights: Dict[str, float] = {k: v for k, v in bw.items()}
    triggers: List[str] = []

    available = [k for k in weights if pillar_meta.get(k, {}).get("has_data", False)]
    missing   = [k for k in weights if not pillar_meta.get(k, {}).get("has_data", False)]
    confidence = round(len(available) / max(len(bw), 1), 2)

    # ── Rule 1: High Conviction insider (CEO purchase > $1M) ──────────────────
    ceo_amt = pillar_meta.get("ins", {}).get("ceo_purchase_amount", 0.0)
    if ceo_amt > 1_000_000 and "ins" in available:
        boost = 0.40 - weights["ins"]
        weights["ins"] = 0.40
        others = [k for k in available if k != "ins"]
        if others:
            cut_each = boost / len(others)
            for k in others:
                weights[k] = max(0.0, weights[k] - cut_each)
        triggers.append(f"ceo_purchase:{ceo_amt / 1e6:.1f}M")

    # ── Rule 2: Momentum (exceptional StockTwits volume > 2σ) ─────────────────
    st_zscore = pillar_meta.get("sent", {}).get("volume_zscore", 0.0)
    if st_zscore > 2.0 and "sent" in available:
        boost = min(0.15, 0.04 * st_zscore)
        weights["sent"] = min(0.50, weights["sent"] + boost)
        triggers.append(f"social_momentum:{st_zscore:.1f}σ")

    # ── Rule 3: Redistribute missing pillar weights ───────────────────────────
    if missing and available:
        lost = sum(weights[k] for k in missing)
        for k in missing:
            weights[k] = 0.0
        per_active = lost / len(available)
        for k in available:
            weights[k] += per_active
        triggers.extend([f"no_data:{k}" for k in missing])
    elif not available:
        weights = {k: v for k, v in bw.items()}   # full fallback to base

    # ── Rule 4: Smart Money Convergence (ins + inst both bullish) ─────────────
    if scores is not None and "ins" in available and "inst" in available:
        ins_s  = scores.get("ins",  0.50)
        inst_s = scores.get("inst", 0.50)
        if ins_s > 0.62 and inst_s > 0.62:
            transfer = 0.04
            for donor in ("sent", "news"):
                if donor in available and weights[donor] >= transfer:
                    weights[donor] -= transfer
                    recipient = "ins" if ins_s >= inst_s else "inst"
                    weights[recipient] = min(0.60, weights[recipient] + transfer)
            triggers.append(f"smart_money:{ins_s:.2f}/{inst_s:.2f}")

    # ═══════════════════════════════════════════════════════════════════════════
    # ENHANCED RULE 5: Social/News Correlation Boost
    # If both news and sentiment are positive → boost Sentiment to 40%
    # ═══════════════════════════════════════════════════════════════════════════
    if scores is not None and "sent" in available and "news" in available:
        sent_s = scores.get("sent", 0.50)
        news_s = scores.get("news", 0.50)
        # Check if both are positive (> 0.55)
        if sent_s > 0.55 and news_s > 0.55:
            # Correlation detected: both positive
            boost = min(0.20, weights["sent"] + 0.10)
            if boost > weights["sent"]:
                diff = boost - weights["sent"]
                weights["sent"] = boost
                # Reduce from other pillars
                for k in [p for p in available if p != "sent"]:
                    weights[k] = max(0.05, weights[k] - diff / len([p for p in available if p != "sent"]))
                triggers.append(f"social_news_correlation:sent={sent_s:.2f},news={news_s:.2f}")
                log.info(f"[SENTIMENT] Social & News correlated positively -> Weight increased to 40%")

    # ═══════════════════════════════════════════════════════════════════════════
    # ENHANCED RULE 6: Convergence Alpha (Signal Override)
    # If Insider > 0.90 AND Sentiment > 0.90 → Global Score = 0.95 min
    # This is handled in score_symbol after computing conviction
    # ═══════════════════════════════════════════════════════════════════════════

    # ── Normalise so weights always sum to exactly 1.0 ───────────────────────
    total_w = sum(weights.values())
    if total_w > 0:
        weights = {k: round(v / total_w, 4) for k, v in weights.items()}

    return weights, confidence, triggers


# ══════════════════════════════════════════════════════════════════════════════
# Signal builder
# ══════════════════════════════════════════════════════════════════════════════

def _conviction_to_signal(
    symbol: str, conviction: float, score: IntelligenceScore
) -> Signal:
    if conviction >= _LONG_THRESHOLD:
        direction = Direction.LONG.value
        t = (conviction - _LONG_THRESHOLD) / (1.0 - _LONG_THRESHOLD)
        target_w = _MIN_TARGET_WEIGHT + t * (_MAX_TARGET_WEIGHT - _MIN_TARGET_WEIGHT)
        just = (
            f"Strong multi-source conviction ({conviction:.0%}).  "
            f"Inst={score.flow_score:.0%}, News={score.congress_score:.0%}, "
            f"Sent={score.sentiment_score:.0%}, "
            f"Ins={score.insider_score:.0%}, Macro={score.macro_score:.0%}."
        )
    elif conviction <= _SHORT_THRESHOLD:
        direction = Direction.SHORT.value
        t = (_SHORT_THRESHOLD - conviction) / _SHORT_THRESHOLD
        target_w = _MIN_TARGET_WEIGHT + t * (_MAX_TARGET_WEIGHT - _MIN_TARGET_WEIGHT)
        just = (
            f"Multi-source bearish signal ({conviction:.0%}).  "
            f"Inst={score.flow_score:.0%}, News={score.congress_score:.0%}, "
            f"Sent={score.sentiment_score:.0%}, "
            f"Ins={score.insider_score:.0%}, Macro={score.macro_score:.0%}."
        )
    else:
        direction = Direction.FLAT.value
        target_w = 0.0
        just = (
            f"Neutral conviction ({conviction:.0%}) — no clear edge.  "
            f"Inst={score.flow_score:.0%}, News={score.congress_score:.0%}, "
            f"Sent={score.sentiment_score:.0%}, "
            f"Ins={score.insider_score:.0%}, Macro={score.macro_score:.0%}."
        )
    return Signal(
        symbol        = symbol,
        direction     = direction,
        target_weight = round(target_w, 4),
        confidence    = conviction,
        justification = just,
        generated_at  = datetime.now(tz=timezone.utc),
    )


# ══════════════════════════════════════════════════════════════════════════════
# Sync API fetchers — each returns (score: float, metadata: Dict)
# metadata always includes has_data: bool and source: str
# ══════════════════════════════════════════════════════════════════════════════

def _fetch_sent_sync(ticker: str) -> Tuple[float, Dict]:
    """
    StockTwits public stream → Enhanced Social & News Sentiment scoring.
    
    BOOSTER LOGIC (per user request):
    - Z-Score on social volume: if 2x normal → score explodes
    - Combine with News correlation: if both positive → sentiment dominates weight
    - Debug logs show each calculation step
    """
    try:
        resp = requests.get(
            f"https://api.stocktwits.com/api/2/streams/symbol/{ticker.upper()}.json",
            headers=_HEADERS,
            timeout=_REQUEST_TO,
        )
        if resp.status_code != 200:
            return _NEUTRAL, {"has_data": False, "source": "stocktwits", "volume_zscore": 0.0}
        data = resp.json()
        messages = data.get("messages", [])

        bull = sum(
            1 for m in messages
            if (m.get("entities") or {}).get("sentiment") and
               (m.get("entities") or {})["sentiment"].get("basic") == "Bullish"
        )
        bear = sum(
            1 for m in messages
            if (m.get("entities") or {}).get("sentiment") and
               (m.get("entities") or {})["sentiment"].get("basic") == "Bearish"
        )
        total_tagged = bull + bear

        if total_tagged == 0:
            return _NEUTRAL, {"has_data": False, "source": "stocktwits", "volume_zscore": 0.0}

        raw_score = bull / total_tagged
        zscore    = _stocktwits_zscore(ticker, float(total_tagged))

        # === SOCIAL SENTIMENT BOOSTER LOGIC ===
        # Rule: Z-Score > 2.0 (2x normal volume) → score explodes
        score = _clamp(0.40 + 0.60 * raw_score)
        
        if zscore > _SENTIMENT_ZSPIKE_THRESHOLD:
            # Apply spike boost
            spike_boost = min(0.25, (zscore - 2.0) * 0.08)
            score = _clamp(score + spike_boost)
            log.info(f"[SENTIMENT] Social Spike detected ({zscore:.1f}x volume) -> Weight increased to {score:.2f}")
        
        # Watchlist-count trending bonus
        watchlist = int((data.get("symbol") or {}).get("watchlist_count", 0))
        trending  = watchlist > 10_000
        if trending:
            score = _clamp(score + 0.05)
            log.info(f"[SENTIMENT] Trending on watchlist ({watchlist:,} watchers) -> Additional boost +0.05")

        log.debug("{} sent bull={} bear={} z={:.2f} score={:.3f}", ticker, bull, bear, zscore, score)
        return score, {
            "has_data":      True,
            "source":        "stocktwits",
            "bullish":       bull,
            "bearish":       bear,
            "total":         total_tagged,
            "volume_zscore": round(zscore, 2),
            "trending":      trending,
            "watchlist":     watchlist,
            "zscore_spike":  zscore > _SENTIMENT_ZSPIKE_THRESHOLD,
        }
    except Exception as exc:
        log.warning("WARNING: sent (StockTwits) failed for {}: {}", ticker, exc)
        return _NEUTRAL, {"has_data": False, "source": "stocktwits", "volume_zscore": 0.0}


def _fetch_ins_sync(ticker: str) -> Tuple[float, Dict]:
    """
    FMP v4 insider-trading → Enhanced Insider Alpha scoring.
    
    BOOSTER LOGIC (per user request):
    - Open Market Form 4 by CEO/CFO/Director within 30 days → score > 0.85
    - Purchase amount > $50,000 → apply force multiplier
    - Debug logs show each calculation step
    """
    key = _fmp_key()
    if not key:
        log.warning("WARNING: ins skipped for {} — FMP_API_KEY missing", ticker)
        return _NEUTRAL, {"has_data": False, "source": "fmp_insider", "ceo_purchase_amount": 0.0}
    try:
        resp = requests.get(
            f"https://financialmodelingprep.com/api/v4/insider-trading"
            f"?symbol={ticker}&limit=50&apikey={key}",
            headers=_HEADERS,
            timeout=_REQUEST_TO,
        )
        data = resp.json() if resp.status_code == 200 else []
        if not isinstance(data, list) or not data:
            return _NEUTRAL, {"has_data": False, "source": "fmp_insider", "ceo_purchase_amount": 0.0}

        buy_value = sell_value = ceo_purchase_amount = 0.0
        # Enhanced tracking for Open Market detection
        open_market_buys = []  # [(amount, owner_type, date)]
        from datetime import datetime, timedelta
        thirty_days_ago = datetime.now() - timedelta(days=_INSIDER_OPEN_MARKET_MIN)
        
        for tx in data:
            tx_type = str(tx.get("transactionType", "")).upper()
            shares  = float(tx.get("securitiesTransacted", 0) or 0)
            price   = float(tx.get("price", 0) or 0)
            value   = abs(shares * price)
            owner   = str(tx.get("typeOfOwner", "")).upper()
            # Parse date
            date_str = tx.get("date", "")
            try:
                tx_date = datetime.strptime(date_str, "%Y-%m-%d") if date_str else None
            except:
                tx_date = None

            if "P-PURCHASE" in tx_type or tx_type == "PURCHASE":
                buy_value += value
                # Check for CEO/CFO/Director
                is_exec = any(r in owner for r in _INSIDER_ROLE_BOOST)
                if is_exec:
                    ceo_purchase_amount += value
                    # Track Open Market purchases
                    if any(om in tx_type for om in _OPEN_MARKET_TYPES):
                        if tx_date and tx_date >= thirty_days_ago:
                            open_market_buys.append((value, owner, date_str))
                            log.info(f"[INSIDER] Detected Open Market Buy of ${value:,.0f} by {owner} on {date_str}")

            elif "SALE" in tx_type:
                sell_value += value

        total = buy_value + sell_value
        if total == 0:
            return _NEUTRAL, {"has_data": False, "source": "fmp_insider", "ceo_purchase_amount": 0.0}

        # Base ratio calculation
        ratio = buy_value / total
        score = _clamp(0.40 + 0.60 * ratio)

        # === INSIDER ALPHA BOOSTER LOGIC ===
        # Rule 1: Open Market Form 4 by CEO/CFO/Director within 30 days → score > 0.85
        if open_market_buys:
            # Find highest conviction buy
            max_open_market = max(buys[0] for buys in open_market_buys)
            if max_open_market >= _INSIDER_MIN_AMOUNT_FORCE:
                score = max(score, _INSIDER_CONVICTION_FLOOR)
                log.info(f"[INSIDER] Open Market conviction detected (${max_open_market:,.0f}) -> Score forced to {score:.2f}")
        
        # Rule 2: Force multiplier for purchases > $50k
        if ceo_purchase_amount >= _INSIDER_MIN_AMOUNT_FORCE:
            # Apply multiplier boost
            multiplier = min(0.15, (ceo_purchase_amount / 1_000_000) * 0.10)
            score = _clamp(score + multiplier)
            log.info(f"[INSIDER] CEO purchase ${ceo_purchase_amount:,.0f} > $50k -> Multiplier boost +{multiplier:.2f}")

        # Legacy hard floor for $1M+ CEO purchases (keep for backward compat)
        if ceo_purchase_amount > 1_000_000:
            score = _clamp(max(score, 0.85))

        log.debug("{} ins buy={:.0f} sell={:.0f} ceo={:.0f} score={:.3f}",
                  ticker, buy_value, sell_value, ceo_purchase_amount, score)
        return score, {
            "has_data":            True,
            "source":              "fmp_insider",
            "buy_value":           round(buy_value, 0),
            "sell_value":          round(sell_value, 0),
            "ceo_purchase_amount": round(ceo_purchase_amount, 0),
            "open_market_buys":    len(open_market_buys),
            "max_open_market":     max((buys[0] for buys in open_market_buys), default=0.0),
        }
    except Exception as exc:
        log.warning("WARNING: ins (FMP insider) failed for {}: {}", ticker, exc)
        return _NEUTRAL, {"has_data": False, "source": "fmp_insider", "ceo_purchase_amount": 0.0}


def _fetch_inst_sync(ticker: str) -> Tuple[float, Dict]:
    """
    FMP v3 institutional-holder → Enhanced Institutional Whales scoring.
    
    BOOSTER LOGIC (per user request):
    - Calculate Net Inflow: institutions increased position in last quarter (13F)
    - Major funds (BlackRock, Vanguard, Renaissance) > 5% increase → institutional dominates
    - Debug logs show each calculation step
    """
    key = _fmp_key()
    if not key:
        log.warning("WARNING: inst skipped for {} — FMP_API_KEY missing", ticker)
        return _NEUTRAL, {"has_data": False, "source": "fmp_inst"}
    try:
        resp = requests.get(
            f"https://financialmodelingprep.com/api/v3/institutional-holder/{ticker}"
            f"?apikey={key}",
            headers=_HEADERS,
            timeout=_REQUEST_TO,
        )
        data = resp.json() if resp.status_code == 200 else []
        if not isinstance(data, list) or not data:
            return _NEUTRAL, {"has_data": False, "source": "fmp_inst"}

        total_change = total_shares = 0.0
        holders_count = 0
        # Track major fund increases
        major_fund_increases = []  # [(fund_name, change_pct)]
        
        for holder in data[:20]:
            change = float(holder.get("change", 0) or 0)
            shares = float(holder.get("shares", 0) or 0)
            holder_name = str(holder.get("holderName", "")).upper()
            total_change += change
            total_shares += shares
            holders_count += 1
            
            # Check for major funds increase
            if shares > 0 and change > 0:
                change_pct = change / shares
                if any(mf in holder_name for mf in _MAJOR_FUNDS):
                    if change_pct >= _INST_MAJOR_INCREASE_THRESHOLD:
                        major_fund_increases.append((holder_name, change_pct))
                        log.info(f"[INSTITUTIONAL] {holder_name} increased position by {change_pct:.1%}")

        if total_shares == 0 or holders_count == 0:
            return _NEUTRAL, {"has_data": False, "source": "fmp_inst"}

        # Calculate Net Inflow ratio
        net_ratio = total_change / max(total_shares, 1)
        score = _clamp(0.50 + min(0.40, max(-0.40, net_ratio * 10)))

        # === INSTITUTIONAL WHALES BOOSTER LOGIC ===
        # Rule: Major funds (BlackRock, Vanguard, Renaissance) > 5% increase → dominate weight
        if major_fund_increases:
            # Apply whale boost
            whale_boost = min(0.20, len(major_fund_increases) * 0.05)
            score = _clamp(score + whale_boost)
            log.info(f"[INSTITUTIONAL] {len(major_fund_increases)} major fund(s) with >5% increase -> "
                     f"Weight boost +{whale_boost:.0%}, Score adjusted to {score:.2f}")

        log.debug("{} inst holders={} net_ratio={:.4f} score={:.3f}",
                  ticker, holders_count, net_ratio, score)
        return score, {
            "has_data":            True,
            "source":              "fmp_inst",
            "holders_count":      holders_count,
            "net_change":          round(total_change, 0),
            "net_ratio":           round(net_ratio, 6),
            "major_fund_increases": len(major_fund_increases),
            "whale_details":       major_fund_increases,
        }
    except Exception as exc:
        log.warning("WARNING: inst (FMP institutional) failed for {}: {}", ticker, exc)
        return _NEUTRAL, {"has_data": False, "source": "fmp_inst"}


def _fetch_news_sync(ticker: str) -> Tuple[float, Dict]:
    """
    Finnhub company-news (last 7 days) + VADER headline sentiment.
    
    Enhanced to track correlation with social sentiment for combined scoring.
    """
    key = _finnhub_key()
    if not key:
        log.warning("WARNING: news skipped for {} — FINNHUB_API_KEY missing", ticker)
        return _NEUTRAL, {"has_data": False, "source": "finnhub_news"}
    try:
        from datetime import date, timedelta
        today    = date.today()
        week_ago = today - timedelta(days=7)
        resp = requests.get(
            f"https://finnhub.io/api/v1/company-news"
            f"?symbol={ticker}&from={week_ago.isoformat()}&to={today.isoformat()}&token={key}",
            headers=_HEADERS,
            timeout=_REQUEST_TO,
        )
        if resp.status_code != 200:
            return _NEUTRAL, {"has_data": False, "source": "finnhub_news"}
        articles = resp.json()
        if not isinstance(articles, list) or not articles:
            return _NEUTRAL, {"has_data": False, "source": "finnhub_news", "article_count": 0}

        import nltk as _nltk
        try:
            from nltk.sentiment.vader import SentimentIntensityAnalyzer as _SIA
        except LookupError:
            _nltk.download("vader_lexicon", quiet=True)
            from nltk.sentiment.vader import SentimentIntensityAnalyzer as _SIA
        _sia = _SIA()
        compounds = [
            _sia.polarity_scores(a.get("headline", ""))["compound"]
            for a in articles[:30]
        ]
        if not compounds:
            return _NEUTRAL, {"has_data": False, "source": "finnhub_news"}
        mean = sum(compounds) / len(compounds)
        
        # === NEWS SENTIMENT BOOSTER ===
        # Track positive vs negative articles for correlation detection
        positive_articles = sum(1 for c in compounds if c > 0.1)
        negative_articles = sum(1 for c in compounds if c < -0.1)
        
        score = _clamp((mean + 1) / 2)
        
        # News volume spike detection
        if len(articles) >= 10:
            score = _clamp(score + 0.03)
            log.info(f"[NEWS] High article volume ({len(articles)} articles) -> Score boost +0.03")

        log.debug("{} news articles={} compound={:.3f} score={:.3f}",
                  ticker, len(compounds), mean, score)
        return score, {
            "has_data":        True,
            "source":          "finnhub_news",
            "article_count":   len(compounds),
            "mean_compound":   round(mean, 3),
            "positive_count":  positive_articles,
            "negative_count":  negative_articles,
            "news_sentiment":  "positive" if mean > 0.1 else "negative" if mean < -0.1 else "neutral",
        }
    except Exception as exc:
        log.warning("WARNING: news (Finnhub) failed for {}: {}", ticker, exc)
        return _NEUTRAL, {"has_data": False, "source": "finnhub_news"}


def _fetch_macro_sync(ticker: str) -> Tuple[float, Dict]:
    """Finnhub analyst consensus (strongBuy→sell scale) as macro signal."""
    key = _finnhub_key()
    if not key:
        log.warning("WARNING: macro skipped for {} — FINNHUB_API_KEY missing", ticker)
        return _NEUTRAL, {"has_data": False, "source": "finnhub_analyst"}
    try:
        resp = requests.get(
            f"https://finnhub.io/api/v1/stock/recommendation?symbol={ticker}&token={key}",
            headers=_HEADERS,
            timeout=_REQUEST_TO,
        )
        data = resp.json()
        if not isinstance(data, list) or not data:
            return _NEUTRAL, {"has_data": False, "source": "finnhub_analyst"}
        rec   = data[0]
        sb    = int(rec.get("strongBuy",  0) or 0)
        b     = int(rec.get("buy",        0) or 0)
        h     = int(rec.get("hold",       0) or 0)
        s     = int(rec.get("sell",       0) or 0)
        ss    = int(rec.get("strongSell", 0) or 0)
        total = sb + b + h + s + ss
        if total == 0:
            return _NEUTRAL, {"has_data": False, "source": "finnhub_analyst"}
        raw   = (sb * 1.0 + b * 0.75 + h * 0.50 + s * 0.25) / total
        score = _clamp(0.10 + raw * 0.80)
        log.debug("{} macro strongBuy={} buy={} hold={} sell={} ss={} score={:.3f}",
                  ticker, sb, b, h, s, ss, score)
        return score, {
            "has_data":  True,
            "source":    "finnhub_analyst",
            "strongBuy": sb, "buy": b, "hold": h, "sell": s, "strongSell": ss,
            "total":     total,
        }
    except Exception as exc:
        log.warning("WARNING: macro (Finnhub analyst) failed for {}: {}", ticker, exc)
        return _NEUTRAL, {"has_data": False, "source": "finnhub_analyst"}


# ── StockTwits per-ticker volume tracker (rolling 30-observation window) ──────

_st_volume_history: Dict[str, List[float]] = {}


def _stocktwits_zscore(ticker: str, current_total: float) -> float:
    """Z-score of current tagged-message count vs ticker's recent history."""
    hist = _st_volume_history.setdefault(ticker, [])
    hist.append(current_total)
    if len(hist) > 30:
        hist.pop(0)
    if len(hist) < 5:
        return 0.0
    mean = sum(hist) / len(hist)
    std  = math.sqrt(sum((v - mean) ** 2 for v in hist) / len(hist))
    return (current_total - mean) / std if std > 1e-6 else 0.0


# ══════════════════════════════════════════════════════════════════════════════
# Async orchestration
# ══════════════════════════════════════════════════════════════════════════════

async def _run(fn, *args):
    loop = asyncio.get_event_loop()
    return await loop.run_in_executor(_executor, fn, *args)


async def _pillar_sent(ticker: str) -> Tuple[str, float, Dict, str]:
    cache_key = f"p3:sent:{ticker}"
    cached = _cache_get_pillar(cache_key)
    if cached is not None:
        return "sent", cached[0], cached[1], "HIT"
    score, meta = await _run(_fetch_sent_sync, ticker)
    _cache_set_pillar(cache_key, score, meta, _TTL["sent"])
    return "sent", score, meta, "MISS"


